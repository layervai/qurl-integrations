{
  "name": "qurl-gmail-chrome-extension",
  "private": true,
  "version": "1.0.2",
  "description": "Chrome extension for Gmail: upload files to qURL and insert access links into compose drafts.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "icons": "node scripts/generate-icons.js",
    "release": "node scripts/build-release.js",
    "package:release": "node scripts/package-release.js",
    "test": "node --test test/*.test.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "publish:patch": "node scripts/bump-version.js patch && node scripts/package-release.js",
    "publish:minor": "node scripts/bump-version.js minor && node scripts/package-release.js",
    "publish:major": "node scripts/bump-version.js major && node scripts/package-release.js"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
