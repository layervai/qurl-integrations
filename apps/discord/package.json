    "discord.js": "~14.14.1",
    "express": "~5.2.1",
    "helmet": "~7.2.0",
    "node-cron": "~4.2.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "~30.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "undici": "^6.24.1",
    "lodash": "^4.17.21"
  }
