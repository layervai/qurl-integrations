{
  "name": "qurl-discord-bot",
  "version": "0.1.1",
  "description": "qURL Discord bot — /qurl send + /qurl map for secure one-time resource sharing, GitHub OAuth linking, auto Contributor role",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "register": "node src/register-commands.js",
    "lint": "eslint src tests scripts --max-warnings 0",
    "test": "jest --coverage"
  },
  "keywords": [
    "discord",
    "bot",
    "qurl",
    "layerv",
    "github",
    "oauth"
  ],
  "author": "LayerV",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1036.0",
    "@aws-sdk/client-sqs": "^3.1036.0",
    "@aws-sdk/client-ssm": "^3.1036.0",
    "@aws-sdk/lib-dynamodb": "^3.1036.0",
    "@discordjs/rest": "~2.6.0",
    "@discordjs/ws": "~1.2.3",
    "discord-api-types": "^0.38.33",
    "discord.js": "14.25.1",
    "express": "~5.2.1",
    "helmet": "~7.2.0",
    "jose": "~5.9.6",
    "node-cron": "~4.2.1"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^8.57.1",
    "jest": "~30.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "undici": "^6.24.1",
    "lodash": "^4.17.21"
  }
}
