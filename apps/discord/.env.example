# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
GUILD_ID=your_discord_guild_id

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Allowed GitHub organizations for contributor tracking (comma-separated)
ALLOWED_GITHUB_ORGS=your_github_org

# Server
PORT=3000
BASE_URL=https://your-app.example.com

# Metrics endpoint auth (REQUIRED in production). When set, /metrics requires
# "Authorization: Bearer <METRICS_TOKEN>". Without a value the endpoint
# returns 503 in every environment.
METRICS_TOKEN=

# Encryption-at-rest key (REQUIRED in production). 32 random bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leaving this unset in dev prints a loud "PLAINTEXT STORAGE" warning and
# stores guild API keys + orphaned tokens in the clear. Do not ship without.
KEY_ENCRYPTION_KEY=GENERATE_WITH_COMMAND_ABOVE

# Admin allowlist for /forcelink, /bulklink, /backfill-milestones, /unlinked
# (comma-separated Discord user IDs). Required to use any admin command.
ADMIN_USER_IDS=

# Rate limiting on /auth/github and /webhook/github (integers, > 0)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30

# /qurl send operational knobs
# QURL_SEND_MAX_RECIPIENTS=50
# QURL_SEND_COOLDOWN_MS=30000

# OAuth state expiry (minutes, integer > 0)
# PENDING_LINK_EXPIRY_MINUTES=10

# Weekly digest cron (default Sunday 9am UTC)
# WEEKLY_DIGEST_CRON=0 9 * * 0

# Welcome DM (set to 'false' to disable)
# WELCOME_DM_ENABLED=true

# Log verbosity: error | warn | info | debug (default info)
# LOG_LEVEL=info

# Database (optional - defaults to apps/discord/data/opennhp-bot.db, a
# legacy name kept for back-compat with existing EFS mounts).
# DATABASE_PATH=./data/opennhp-bot.db

# Role/Channel names (optional - defaults shown)
# CONTRIBUTOR_ROLE_NAME=Contributor
# GENERAL_CHANNEL_NAME=general
# CONTRIBUTE_CHANNEL_NAME=contribute
# GITHUB_FEED_CHANNEL_NAME=github-feed

# QURL (secure resource sharing)
QURL_API_KEY=your_qurl_api_key
# Set QURL_ENDPOINT explicitly — defaults to production if omitted in prod,
# or http://localhost:8080 otherwise.
# Prod: https://api.layerv.ai   Staging: https://api.staging.layerv.ai
QURL_ENDPOINT=https://api.example.com

# qurl-s3-connector (file upload + serving)
# Prod: https://get.qurl.link:9808
CONNECTOR_URL=https://connector.example.com:9808

# Google Maps (location autocomplete for /qurl send)
# Restrict the key by HTTP referrer / IP in Google Cloud Console — it ships
# as a query parameter per Google's API design, so it's visible in server
# logs and proxy logs downstream.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
