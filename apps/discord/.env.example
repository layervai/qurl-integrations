# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id

# GUILD_ID is OPTIONAL. Combined with ENABLE_OPENNHP_FEATURES below, it
# selects one of three supported modes:
#
#   GUILD_ID set  + ENABLE_OPENNHP_FEATURES=true  → Single-guild OpenNHP
#     community server. Commands register scoped to the guild (instant
#     updates). Bot auto-creates contributor roles + #contribute /
#     #github-feed channels, sends welcome DMs, tracks PR merges,
#     schedules a weekly digest. Requires ManageRoles + ManageChannels
#     perms in the guild.
#
#   GUILD_ID set  + ENABLE_OPENNHP_FEATURES=false → Single-guild plain
#     /qurl send tool. Commands register scoped to the guild; OpenNHP
#     behaviors are dormant. Only needs 4 runtime perms (ViewChannel,
#     SendMessages, EmbedLinks, UseApplicationCommands).
#
#   GUILD_ID unset + ENABLE_OPENNHP_FEATURES=false → Multi-tenant plain
#     /qurl send tool. Commands register globally (up to 1 hr Discord
#     cache propagation); bot works in every guild it's invited to.
#     Each guild admin runs /qurl setup to configure their own qURL
#     API key (stored encrypted, per-guild). This is the public-bot
#     default.
#
# (GUILD_ID unset + flag true is not a supported combination — OpenNHP
# behaviors need a specific guild cache to target.)
GUILD_ID=

# Enable OpenNHP community features (contributor-role auto-creation and
# assignment, welcome DM, badge announcements, #contribute / #github-feed
# channel creation, weekly digest). DEFAULT: disabled.
#
# Only the literal string "true" enables; every other value — unset,
# empty, "TRUE", "1", "yes" — keeps it off. This is intentional: an
# env-var typo should never silently enable features that demand
# elevated Discord permissions. Set to "true" only in the OpenNHP
# community guild's task-def.
ENABLE_OPENNHP_FEATURES=false

# Process role — selects which subset of the bot runs in this container.
# Default: combined (legacy single-process behavior, backward-compatible).
#
#   combined — Gateway WebSocket + Express HTTP listener + cron jobs all
#              in one process. The right shape for sandbox / local dev /
#              any deployment that hasn't opted into the split.
#
#   gateway  — Discord Gateway client + interaction handlers + cron jobs.
#              No HTTP listener. Deploy as a singleton (desired_count=1):
#              Discord bot tokens admit only one active Gateway connection
#              per token, and two concurrent logins flap session identity.
#
#   http     — Express listener (OAuth callbacks, webhooks, /health,
#              /metrics) only. No Gateway login. Can scale horizontally
#              behind an ALB. Reads `client.rest` (token seeded by
#              http-only-init.js) for outbound Discord REST calls.
#
# Unknown values fail boot loudly. Leave unset to default to combined.
# PROCESS_ROLE=combined

# GitHub OAuth App — REQUIRED only when ENABLE_OPENNHP_FEATURES=true.
# Single-guild-plain and multi-tenant deployments don't mount /auth or
# /webhook routes and don't need these values — the boot check
# (boot-requirements.js) demands them only when the OpenNHP surface is
# active. Safe to leave blank otherwise.
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Dedicated HMAC key for OAuth state tokens. Optional. When set, state
# HMAC uses this instead of GITHUB_CLIENT_SECRET so the two can be rotated
# independently — a compromised client secret no longer enables forgery
# of OAuth state. Recommended for production. Generate with:
#   openssl rand -hex 32
OAUTH_STATE_SECRET=

# Allowed GitHub organizations for contributor tracking (comma-separated)
ALLOWED_GITHUB_ORGS=your_github_org

# Server
PORT=3000
BASE_URL=https://your-app.example.com

# Metrics endpoint auth (REQUIRED in production). When set, /metrics requires
# "Authorization: Bearer <METRICS_TOKEN>". Without a value the endpoint
# returns 503 in every environment.
METRICS_TOKEN=

# Encryption-at-rest key (REQUIRED in production). 32 random bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leaving this unset in dev prints a loud "PLAINTEXT STORAGE" warning and
# stores guild API keys + orphaned tokens in the clear. Do not ship without.
KEY_ENCRYPTION_KEY=GENERATE_WITH_COMMAND_ABOVE

# Previous encryption key for zero-downtime rotation. Optional. When set,
# decrypt falls back to this if the current KEY_ENCRYPTION_KEY can't
# verify the auth tag. Encrypt always uses the current key, so rows are
# transparently re-encrypted on next write. Remove once all rows have
# been re-encrypted (next write after a rolling deploy is sufficient for
# most tables; guild_configs requires /qurl setup).
KEY_ENCRYPTION_KEY_PREV=

# Orphaned OAuth token retention (days). Default 7 in production, 1 in
# dev/staging. Valid range: 1..30. Tokens failing live revocation are
# encrypted at rest and periodically retried; this bounds how long a
# persistently-rejected token lingers.
# ORPHAN_TOKEN_RETENTION_DAYS=7

# Admin allowlist for /forcelink, /bulklink, /backfill-milestones, /unlinked
# (comma-separated Discord user IDs). Required to use any admin command.
ADMIN_USER_IDS=

# Rate limiting on /auth/github and /webhook/github (integers, > 0)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30

# /qurl send operational knobs
# QURL_SEND_MAX_RECIPIENTS=50
# QURL_SEND_COOLDOWN_MS=30000

# OAuth state expiry (minutes, integer > 0)
# PENDING_LINK_EXPIRY_MINUTES=10

# Weekly digest cron (default Sunday 9am UTC)
# WEEKLY_DIGEST_CRON=0 9 * * 0

# Welcome DM (set to 'false' to disable)
# WELCOME_DM_ENABLED=true

# Log verbosity: error | warn | info | debug (default info)
# LOG_LEVEL=info

# Database (optional - defaults to apps/discord/data/opennhp-bot.db, a
# legacy name kept for back-compat with existing EFS mounts).
# DATABASE_PATH=./data/opennhp-bot.db

# Role/Channel names (optional - defaults shown)
# CONTRIBUTOR_ROLE_NAME=Contributor
# GENERAL_CHANNEL_NAME=general
# CONTRIBUTE_CHANNEL_NAME=contribute
# GITHUB_FEED_CHANNEL_NAME=github-feed

# qURL (secure resource sharing)
QURL_API_KEY=your_qurl_api_key
# Set QURL_ENDPOINT explicitly — defaults to production if omitted in prod,
# or http://localhost:8080 otherwise.
# Prod: https://api.layerv.ai   Staging: https://api.staging.layerv.ai
QURL_ENDPOINT=https://api.example.com

# qurl-s3-connector (file upload + serving)
# Prod: https://get.qurl.link:9808
CONNECTOR_URL=https://connector.example.com:9808

# Google Maps (location autocomplete for /qurl send)
# Restrict the key by HTTP referrer / IP in Google Cloud Console — it ships
# as a query parameter per Google's API design, so it's visible in server
# logs and proxy logs downstream.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
