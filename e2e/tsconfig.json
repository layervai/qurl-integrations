{
  "compilerOptions": {
    "target": "ES2022",
    // node16 resolves extensionless relative imports only because this
    // package is CommonJS (no "type": "module" in package.json). Adding
    // "type": "module" later would force `.js` extensions on every
    // relative import across the suite.
    "module": "node16",
    "moduleResolution": "node16",
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["jest", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
